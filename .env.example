# toolbox-web configuration — copy to `.env` and edit.
# `.env` is loaded automatically at startup (by `flask run` and by app.py).
# Every setting below is OPTIONAL; the shown value is the built-in default.
# Lines are commented out where the default is a path computed at runtime.

# ── Network ──────────────────────────────────────────────────────────────────
# Interface the server binds to. 0.0.0.0 = reachable from other machines on the
# LAN; 127.0.0.1 = localhost only (safer default if you don't need remote access).
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000

# ── Auth ─────────────────────────────────────────────────────────────────────
# If set, the config-WRITE endpoints require this value in the X-Toolbox-Token
# header. Reads and command execution are unaffected. Leave empty to disable.
# TOOLBOX_WEB_TOKEN=

# ── Paths (defaults are relative to the app folder or $HOME) ──────────────────
# Main command config file.            default: <app>/config/commands.yaml
# TOOLBOX_WEB_CONFIG=
# llama.cpp preset .ini directory.      default: <app>/config
# TOOLBOX_WEB_PRESETS_DIR=
# sync-models runner script.            default: <app>/scripts/sync_models.py
# TOOLBOX_WEB_SYNC_MODELS=
# curated model list (data).            default: <app>/config/models.yaml
# TOOLBOX_WEB_MODELS_LIST=
# terminal log directory.               default: <app>/logs
# TOOLBOX_WEB_LOG_DIR=
# model symlink store hf-link populates. default: ~/models
# TOOLBOX_WEB_MODELS_DIR=~/models
# path whose disk usage the footer shows. default: ~
# TOOLBOX_WEB_DISK_PATH=~

# ── Hugging Face (standard HF env vars, honored if set) ───────────────────────
# HF_TOKEN=
# HF_HOME=~/.cache/huggingface
