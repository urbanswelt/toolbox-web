[Unit]
Description=Toolbox Web Runner
After=network.target

[Service]
Type=simple
User=%i
WorkingDirectory=/home/%i/toolbox-web
# Host/port come from .env (FLASK_RUN_HOST / FLASK_RUN_PORT), loaded automatically.
ExecStart=/home/%i/.local/bin/uv run flask --app app run
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
