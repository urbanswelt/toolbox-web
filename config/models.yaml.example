# Curated model list — `sync-models` downloads each repo and links it into the
# model store (~/models). Each entry: name (the ~/models/<name> symlink), repo
# (HF id), pattern (include glob; blank or "*" = all files).
models:
- {name: Step-3.7-Flash-GGUF, repo: stepfun-ai/Step-3.7-Flash-GGUF, pattern: Q4_K_S/*}
